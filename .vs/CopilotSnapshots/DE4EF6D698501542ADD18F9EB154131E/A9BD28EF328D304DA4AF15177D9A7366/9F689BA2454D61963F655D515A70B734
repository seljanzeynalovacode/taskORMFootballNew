using FootbolLigasORM.DAL.Context;
using FootbolLigasORM.DAL.Repostory;
using Microsoft.EntityFrameworkCore;
using Microsoft.Extensions.Configuration;
using Microsoft.Extensions.DependencyInjection;
using FootbolLigasORM.UI;

namespace FootbolLigasORM.UI
{
    internal class Program
    {
        static async Task Main(string[] args)
        {
            // Build configuration - read from appsettings.json in the UI project
            var jsonPath = Path.Combine(Directory.GetCurrentDirectory(), "appsettings.json");
            var configuration = new ConfigurationBuilder()
                .Build();

            var services = new ServiceCollection();

            // Register DbContext so ProductRepository can be resolved
            services.AddDbContext<AppDbContext>(options =>
            {
                var connectionString = "Data Source=BETA05\\SQLEXPRESS;Initial Catalog=MarketDB;Integrated Security=True;Connect Timeout=30;Encrypt=True;Trust Server Certificate=True;Application Intent=ReadWrite;Multi Subnet Failover=False";
                options.UseSqlServer(connectionString);
            });

            services.AddScoped<ClubRepository>();

            var provider = services.BuildServiceProvider();

            using var scope = provider.CreateScope();
            var repo = scope.ServiceProvider.GetRequiredService<ClubRepository>();

            Console.WriteLine("Product menu starting...");
            object value = await MenuOperation.Run(repo);

            Console.WriteLine("Exiting.");
        }
    }
}
