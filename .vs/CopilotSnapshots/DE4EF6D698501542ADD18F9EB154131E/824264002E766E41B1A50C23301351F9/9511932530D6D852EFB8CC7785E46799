using System;
using FootbolLigasORM.DAL.Entities;

namespace FootbolLigasORM.DAL.Entities
{
    public class Matches
    {
        // Primary key
        public int Id { get; set; }

        // When the match takes place
        public DateTime MatchDate { get; set; }

        // Home and away clubs
        public int HomeClubId { get; set; }
        public Clubs? HomeClub { get; set; }

        public int AwayClubId { get; set; }
        public Clubs? AwayClub { get; set; }

        // Stadium where the match is played
        public int? StadiumId { get; set; }
        public Stadiums? Stadium { get; set; }

        // Scores (nullable until match is played)
        public int? HomeScore { get; set; }
        public int? AwayScore { get; set; }

        // Attendance and referee information
        public int Attendance { get; set; }
        public string Referee { get; set; } = string.Empty;

        // Competition or round (league, cup, friendly, etc.)
        public string Competition { get; set; } = string.Empty;

        // Whether the match has been played
        public bool IsPlayed => HomeScore.HasValue && AwayScore.HasValue;
    }
}
